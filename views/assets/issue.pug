html
  head
    title Issue Asset

  body

    h1 Issue Asset

    form(action='/issue-asset' method='POST')

      div
        label Employee Name
        input(type='text' name='employee_name' required)

      br

      div
        label Asset Name
        input(type='text' name='asset_name' required)

      br

      div
        label Issue Date
        input(type='date' name='issue_date' required)

      br

      button(type='submit') Issue Asset